# Normalize all text files to LF on commit
* text=auto eol=lf

# Source
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.zip       binary
*.tar.gz    binary
